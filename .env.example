# === POLYMATH RAG v3.3 ===
# Copy this file to .env and fill in your secrets.
#
#   cp .env.example .env
#   # then edit .env — anything marked CHANGE_ME or empty must be filled
#
# Security:
#   - .env is gitignored. Never commit it.
#   - Generate secrets with `openssl rand -base64 64` (auth) or
#     `openssl rand -base64 32` (passwords).
#   - Cloud LLM keys are optional — the stack runs fully local via Ollama
#     if you set up any embedding/synthesis path with no cloud keys at all.

# ============================================================
# DATABASES
# ============================================================
MONGODB_URI=mongodb://polymath:CHANGE_ME_mongo_password@mongodb:27017/polymath?authSource=admin
MONGO_USER=polymath
MONGO_PASSWORD=CHANGE_ME_mongo_password

QDRANT_URL=http://qdrant:6333
# One-bit binary search for Polymath-managed dense vectors. Qdrant retains the
# original float vectors for quality-preserving rescoring.
QDRANT_BINARY_QUANTIZATION_ENABLED=true
QDRANT_BINARY_QUANTIZATION_ALWAYS_RAM=true
QDRANT_BINARY_QUANTIZATION_RESCORE=true
QDRANT_BINARY_QUANTIZATION_OVERSAMPLING=2.0

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_password
# Set to false to skip the graph layer (vector-only retrieval, smaller footprint)
NEO4J_ENABLED=true

REDIS_URL=redis://redis:6379

# ============================================================
# LIVE WEB SEARCH (opt-in chat toggle)
# ============================================================
# SearXNG runs inside docker-compose at http://searxng:8080 and is exposed
# on the host at http://localhost:8080. Chat only uses it when the Web toggle
# is enabled for a specific turn.
LIVE_WEB_SEARCH_ENABLED=true
SEARXNG_URL=http://searxng:8080
SEARXNG_BASE_URL=http://localhost:8080/
SEARXNG_ENGINES=duckduckgo,bing,mojeek,wikipedia
SEARXNG_TIMEOUT_SECONDS=6.0
STRACT_SEARCH_ENABLED=true
STRACT_SEARCH_URL=https://stract.com/beta/api/search
STRACT_SEARCH_TIMEOUT_SECONDS=4.0
LIVE_WEB_SEARCH_MAX_RESULTS=7
LIVE_WEB_SEARCH_CANDIDATE_RESULTS=15
LIVE_WEB_QUERY_EXPANSION_TIMEOUT_SECONDS=2.0
# Full-page fetch layer. SearXNG discovers URLs, snippets are reranked, and
# only the best few URLs are extracted. LIVE_WEB_PAGE_FETCHER=auto uses
# Trafilatura when installed and falls back to native httpx + BeautifulSoup.
# OBSCURA_COMMAND is only used as an allowlisted JS fallback after static
# extraction fails.
LIVE_WEB_SEARCH_FETCH_FULL_PAGES=true
LIVE_WEB_FETCH_MAX_PAGES=6
LIVE_WEB_PAGE_FETCHER=auto
LIVE_WEB_OBSCURA_DOMAINS=civitai.com,create.roblox.com,gumroad.com,polymarket.com,producthunt.com,rolimons.com,tradingview.com
LIVE_WEB_FETCH_CACHE_TTL_SECONDS=900
OBSCURA_COMMAND=/usr/local/bin/obscura
OBSCURA_TIMEOUT_SECONDS=10.0
OBSCURA_MAX_CHARS=4000
LIVE_WEB_VIDEO_TRANSCRIPT_MIN_CHARS=80
LIVE_WEB_VIDEO_TRANSCRIPT_MAX_CHARS=12000

# ============================================================
# LITELLM (cloud LLM router)
# ============================================================
LITELLM_URL=http://litellm:4000
# openssl rand -base64 32
LITELLM_MASTER_KEY=CHANGE_ME_litellm_master_key

# ============================================================
# LOCAL LLM (Ollama on host machine)
# ============================================================
# host.docker.internal works on Docker Desktop (Win/Mac).
# On native Linux Docker, use the host's bridge IP or set extra_hosts.
OLLAMA_URL=http://host.docker.internal:11434

# ============================================================
# AUTH
# ============================================================
# openssl rand -base64 64
AUTH_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_64
# Initial admin password. Change it after first login.
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_admin_password
# Static API key required by the MCP sidecar when MCP_REQUIRE_AUTH=true.
# Prefer user-scoped keys from Settings -> MCP Server for normal remote agents.
# This is NOT an OpenAI/Anthropic provider key; it only authenticates to
# Polymath's MCP server.
MCP_API_KEY=CHANGE_ME_mcp_api_key

# ============================================================
# CLOUD LLM PROVIDER KEYS (all optional — fill what you'll use)
# ============================================================
# At least ONE of these (or a working Ollama path) is needed for synthesis.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Below are optional providers wired through LiteLLM wildcard routes.
# Leave empty to disable. Non-empty placeholders ("ui-managed-placeholder")
# keep LiteLLM's wildcard route loadable when keys are managed per-user
# via Settings -> API Keys (Fernet-encrypted in MongoDB).
MISTRAL_API_KEY=
Z_AI_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
MIMO_API_KEY=

# ============================================================
# CLOUDFLARE TUNNEL (optional — for publishing the app behind your domain)
# ============================================================
# Tunnel token from Cloudflare Zero Trust → Networks → Tunnels → <name>.
# Looks like eyJhIjoi.... Leave blank to disable the cloudflared service.
CLOUDFLARE_TUNNEL_TOKEN=
# Public MCP base URL shown in Settings -> MCP snippets. Leave blank for
# localhost. When using a Cloudflare tunnel, set this to the MCP hostname
# you configured in the tunnel's Public Hostnames table.
# Do not include /mcp here; the connection endpoint is MCP_PUBLIC_URL + /mcp.
#   Example: MCP_PUBLIC_URL=https://mcp.kingsleylab.xyz
MCP_PUBLIC_URL=
# Keep true unless MCP is only reachable on a trusted local network.
# Required when the tunnel exposes MCP to the public internet.
MCP_REQUIRE_AUTH=true
# Default source chunk count for MCP retrieval tools when top_k is omitted.
MCP_DEFAULT_TOP_K=5

# ============================================================
# APPLICATION
# ============================================================
APP_ENV=development
LOG_LEVEL=info
# Default local workstation services. Remove mcp if you do not need agent
# access, or add cloudflare/admin/automation as needed.
COMPOSE_PROFILES=local-embed,local-rerank,local-parser,mcp

# Docling is ingest-only. MD/TXT/HTML/code and fast-text PDFs parse locally;
# DOCX/EPUB/office-like files use the optional local-parser profile.
# Set off/local if you want the backend to fail fast instead of contacting
# Docling for sidecar-only formats.
DOCLING_SIDECAR_POLICY=off
# Docling sidecar unloads its heavy converter after this idle window.
DOCLING_IDLE_UNLOAD_SECONDS=300
# Default false keeps the converter warm during multi-file batches. Set true
# only for one-off, memory-sensitive sidecar parses.
DOCLING_AUTO_UNLOAD_AFTER_PARSE=false

# ============================================================
# DOCKER VOLUME ROOT
# ============================================================
# All bind mounts live under this root. Use a fast SSD outside Docker
# Desktop's WSL VHDX so vector indexes don't bloat your virtual disk.
#   Windows:  C:/PolymathRuntime  or  E:/PolymathRuntime
#   Linux:    /mnt/ssd/polymath   or  $HOME/polymath-runtime
POLYMATH_DOCKER_DATA_ROOT=C:/PolymathRuntime
# Bind-mounted config/scripts that should travel with the runtime export.
POLYMATH_RUNTIME_BINDS_ROOT=C:/PolymathRuntime/binds
# HuggingFace caches stay here. Symlinks must be supported on the underlying
# filesystem (NTFS on Windows is fine; some network shares are not).
POLYMATH_CACHE_ROOT=C:/PolymathRuntime
# Where pre-staged model files live (Qwen3-Embedding-0.6B, optional GGUF reranker)
POLYMATH_MODELS_ROOT=C:/PolymathRuntime/models
# Host folder mounted read-only inside the backend as /ingest-source.
# Put large local corpora here, then use /ingest-source/<folder> in the UI.
POLYMATH_INGEST_SOURCE_ROOT=C:/PolymathRuntime/ingest-source

# ============================================================
# RERANKER (llama.cpp + Qwen3-Reranker-0.6B Q8 GGUF by default)
# ============================================================
RERANKER_URL=http://reranker:8080
RERANKER_MODEL=qwen3-reranker-0.6b-q8_0
RERANKER_SCORE_SCALE=probability
RERANKER_LOW_CONFIDENCE_THRESHOLD=-2.5
RERANKER_TIMEOUT_SECONDS=30
RERANKER_QUEUE_TIMEOUT_SECONDS=5
RERANKER_HTTP_BATCH_SIZE=24
RERANKER_CIRCUIT_BREAKER_SECONDS=120
GRAPH_FACT_SEED_TIMEOUT_SECONDS=5
GRAPH_SYNTHESIS_TIMEOUT_SECONDS=30
LOCAL_RERANKER_ENABLED=false
LLAMA_CPP_SERVER_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
LLAMA_RERANKER_HF_REPO=ggml-org/Qwen3-Reranker-0.6B-Q8_0-GGUF
LLAMA_RERANKER_HF_FILE=qwen3-reranker-0.6b-q8_0.gguf
LLAMA_RERANKER_GPU_LAYERS=99
LLAMA_RERANKER_CTX_SIZE=4096
LLAMA_RERANKER_PARALLEL=1
LLAMA_RERANKER_BATCH_SIZE=8192
LLAMA_RERANKER_UBATCH_SIZE=8192
LLAMA_RERANKER_CACHE_RAM_MB=0
# Keep the reranker warm. -1 disables llama.cpp sleep/unload; this avoids a
# 5-10s cold start on the next query after idle.
LLAMA_RERANKER_SLEEP_IDLE_SECONDS=-1

# ============================================================
# DEFAULT MODELS (optional — falls back to per-user settings)
# ============================================================
# Global chat-model fallback used when a request carries no model and the
# conversation has none stored. The web UI always sends a model (header
# selector), but MCP/agent callers (Hermes, OpenClaw) usually don't — leave
# this empty and polymath_chat_query raises "No chat model configured".
# Set it to any model your litellm proxy can route, e.g. deepseek/deepseek-chat.
DEFAULT_COMPLETION_MODEL=deepseek/deepseek-chat
# Output cap sent by the chat UI. DeepSeek V4 supports much more, but 16k keeps
# normal turns roomy without letting reasoning-mode calls run away by default.
MAX_COMPLETION_TOKENS=16384
AGENTIC_MODEL=
HYDE_MODEL=

# Corpus-grounded query translation. The deterministic resolver is enabled by
# default and performs no generation calls. The optional planner requires all
# three explicit gates below: enabled, a routable model, and a positive durable
# lifetime call budget.
CORPUS_VOCABULARY_RESOLVER_ENABLED=true
QUERY_PLAN_VOCABULARY_DEADLINE_SECONDS=15
GROUNDED_QUERY_PLANNER_ENABLED=false
GROUNDED_QUERY_PLANNER_MODEL=
GROUNDED_QUERY_PLANNER_MAX_CALLS_TOTAL=0
GROUNDED_QUERY_PLANNER_TIMEOUT_SECONDS=8
GROUNDED_QUERY_PLANNER_CACHE_TTL_HOURS=24
GROUNDED_QUERY_PLANNER_MIN_ALIGNMENT=0.45
GROUNDED_QUERY_PLANNER_STEP_BACK_MIN_ALIGNMENT=0.35

# ============================================================
# EMBEDDING (Qwen3-Embedding-0.6B, 1024d)
# ============================================================
# Fits in ~2 GB VRAM at batch 64. Lower for cards with < 8 GB VRAM.
LOCAL_EMBEDDER_ENABLED=true
LOCAL_EMBED_BATCH_SIZE=64
EMBED_BATCH_SIZE=64
EMBEDDER_LOCAL_TIMEOUT_SECONDS=120
EMBEDDER_QUERY_TIMEOUT_SECONDS=30

# Defer expensive graph/Brain View cache rebuilds while a durable ingest batch
# is actively running. They will run after the batch settles.
GRAPH_CACHE_WARMUP_SKIP_DURING_ACTIVE_INGEST=true
GRAPH_CACHE_WARMUP_ACTIVE_INGEST_DEFER_SECONDS=120

# ============================================================
# INGESTION CONCURRENCY
# ============================================================
# Doc-worker parallelism. Lower for small machines (24 GB VRAM and under
# work well at 4/4/4). Higher saturates >= 96 GB pro cards.
INGEST_PRE_VECTOR_DOC_CAP=8
INGEST_GRAPH_DOC_CAP=8
INGEST_MAX_PARSE_JOBS=8
INGEST_MAX_MODEL_PHASE_DOCS=8
INGEST_MAX_CLOUD_MODEL_PHASE_DOCS=4
INGEST_MAX_GRAPH_MODEL_PHASE_DOCS=8
# Durable file spool for backend-owned folder ingest. 2 GiB covers raw source
# bytes for the intended 1 GiB markdown/text corpus with room for retry state.
INGEST_FILE_STORAGE_DIR=/data/ingest-files
# Host-visible Quick Upload drop-off. Compose maps this to
# ${POLYMATH_DOCKER_DATA_ROOT}/volumes/ingest-drop-off on the host.
INGEST_DROP_OFF_DIR=/data/ingest-drop-off
INGEST_FILE_STORAGE_MAX_BYTES=2147483648

# ============================================================
# EXTRACTION (Ghost B entity/relation extractor)
# ============================================================
# Local sidecar route used by Docker when native MLX/Metal or ONNX/CUDA runs
# outside the backend container. In Settings -> Ingestion, these seed the
# default Extraction Engines list; UI changes apply on the next ingest.
LOCAL_GHOST_B_EXTRACT_MODE=auto
LOCAL_GHOST_B_EXTRACT_URL=http://host.docker.internal:8084
LOCAL_GHOST_B_EXTRACT_TIMEOUT_S=1800
LOCAL_GHOST_B_EXTRACT_SLICE=2048
# Keep false for production. ONNX endpoints without CUDAExecutionProvider are
# rejected so a silent CPU fallback cannot stall future ingestion batches.
LOCAL_GHOST_B_ALLOW_ONNX_CPU_FALLBACK=false

# IMPORTANT: max_tokens must accommodate any reasoning-mode tokens AND
# the JSONL content. DeepSeek v4-flash defaults to thinking-mode ON:
# Ghost B disables it via thinking={"type":"disabled"} so reasoning
# tokens don't eat the entire budget — see GOTCHAS § "Ghost B + DeepSeek
# thinking-mode". If you swap to a non-DeepSeek reasoning model
# (Claude with extended thinking, OpenAI o-series, etc.), wire its
# disable knob the same way or budget for ~3x output tokens.
EXTRACTION_MAX_TOKENS=6144
EXTRACTION_OUTPUT_MODE=jsonl
EXTRACTION_JSON_OBJECT_MAX_ENTITIES_PER_CHUNK=8
EXTRACTION_JSON_OBJECT_MAX_RELATIONS_PER_CHUNK=12
EXTRACTION_JSON_OBJECT_MAX_FACTS_PER_CHUNK=4
EXTRACTION_EVIDENCE_MAX_CHARS=120
EXTRACTION_FACT_VALUE_MAX_CHARS=160
EXTRACTION_RESCUE_MAX_TOKENS=4096
EXTRACTION_MAX_INPUT_TOKENS=700
# Wall-clock cap on the per-doc chunker. Pathological content (code/math/
# table blocks with no sentence boundaries — see PBR4) can pin the chunker
# at 100% CPU for many minutes; this timeout marks the doc failed and the
# batch moves on. Raise if you have legitimately huge docs you want to
# process even if it takes >10 min.
TIER_CHUNKER_DOC_TIMEOUT_SECONDS=600
# Large/section-dense documents bypass the normal semantic splitter and use
# the deterministic regex + sentence-merge fallback immediately.
TIER_CHUNKER_PATHOLOGICAL_CHAR_THRESHOLD=350000
TIER_CHUNKER_PATHOLOGICAL_SECTION_THRESHOLD=5000
TIER_CHUNKER_PATHOLOGICAL_FALLBACK_TIMEOUT_SECONDS=180
# Parser-side line cap. Set 15 above the per-type theoretical max
# (14 entities + 20 relations + 5 facts + 1 sentinel = 40). Going below
# the per-type max truncates dense chunks and surfaces them as
# `error_type=line_cap_exceeded` audit events even when the model output
# is clean. Bumping above ~64 is wasteful — model can't emit more
# distinct items because duplicates are forbidden.
EXTRACTION_MAX_TOTAL_LINES=55
EXTRACTION_RESCUE_MAX_TOTAL_LINES=30
EXTRACTION_JSONL_MAX_CALLS=2
EXTRACTION_FOREGROUND_MAX_CALLS=2
EXTRACTION_GLOBAL_MAX_CONCURRENT=180
EXTRACTION_MAX_ACTIVE_DOCS=1
# The dedicated ingest worker may drain durable repair queues automatically.
# Query/API containers keep INGEST_RUNNERS_ENABLED=false and never execute them.
INGEST_AUTO_REPAIR_ENABLED=true
INGEST_AUTO_REPAIR_POLL_SECONDS=120
INGEST_AUTO_REPAIR_CORPUS_LIMIT=3
INGEST_AUTO_REPAIR_RUN_DOCUMENT_PIPELINE=true
INGEST_AUTO_REPAIR_RUN_EXTRACTION=true
INGEST_AUTO_REPAIR_RUN_SUMMARIES=true
INGEST_AUTO_REPAIR_RUN_GRAPH=true
INGEST_AUTO_REPAIR_DOCUMENT_RUN_LIMIT=25
INGEST_AUTO_REPAIR_EXTRACTION_RUN_LIMIT=500
INGEST_AUTO_REPAIR_SUMMARY_RUN_LIMIT=500
EXTRACTION_FAILURE_PAUSE_PERCENT=25
EXTRACTION_FAILURE_PAUSE_MIN_CHUNKS=20
EXTRACTION_JSONL_DEBUG_RAW=false
EXTRACTION_ERROR_AUDIT_ENABLED=true
EXTRACTION_ERROR_AUDIT_MAX_FAILED_ATTEMPTS_PER_DOC=200
EXTRACTION_ERROR_AUDIT_MAX_SUCCESS_ATTEMPTS_PER_DOC=2
EXTRACTION_ERROR_AUDIT_RAW_FIRST_CHARS=200
EXTRACTION_ERROR_AUDIT_RAW_LAST_CHARS=400
EXTRACTION_MAX_ENTITIES_PER_CHUNK=18
EXTRACTION_MAX_RELATIONS_PER_CHUNK=20
EXTRACTION_RESCUE_MAX_ENTITIES_PER_CHUNK=8
EXTRACTION_RESCUE_MAX_RELATIONS_PER_CHUNK=8
EXTRACTION_ENABLE_FACTS=true
EXTRACTION_MAX_FACTS_PER_CHUNK=5
# 0.0 disables LLM-self-reported confidence filtering. Quality is enforced
# by the schema constraints; raise only after eyeballing your model's
# confidence distribution.
ENTITY_CONFIDENCE_THRESHOLD=0.0

# ============================================================
# AUTOMATION (optional — n8n workflow runner)
# ============================================================
N8N_URL=http://n8n:5678

# ============================================================
# E2E TEST KEYS (optional — only needed to run Playwright autoresearch tests)
# ============================================================
POLYMATH_TEST_KIMI_KEY=
POLYMATH_TEST_DEEPSEEK_KEY=
POLYMATH_TEST_OPENROUTER_KEY=
POLYMATH_TEST_MODAL_TOKEN_ID=
POLYMATH_TEST_MODAL_TOKEN_SECRET=
# Phrase-aware unified retrieval planner. False is the immediate rollback.
QUERY_PLAN_V2=true
QUERY_PLAN_V2_SHADOW=true
QUERY_PLAN_REPAIR_DEADLINE_SECONDS=1.25
FAST_SUMMARY_DEADLINE_SECONDS=1.25
QUERY_PLAN_HYBRID_TOTAL_DEADLINE_SECONDS=7.5
QUERY_PLAN_GRAPH_TOTAL_DEADLINE_SECONDS=9.5
QUERY_PLAN_EMBED_DEADLINE_SECONDS=5.0
QUERY_PLAN_RETRIEVAL_DEADLINE_SECONDS=4.0
QUERY_PLAN_GRAPH_DEADLINE_SECONDS=4.0
QUERY_PLAN_IDENTITY_DEADLINE_SECONDS=2.0
QUERY_PLAN_RERANK_DEADLINE_SECONDS=6.0
QUERY_PLAN_HYBRID_RERANK_CANDIDATES=16
QUERY_PLAN_GRAPH_RERANK_CANDIDATES=20
QUERY_PLAN_HYDRATE_DEADLINE_SECONDS=2.0
