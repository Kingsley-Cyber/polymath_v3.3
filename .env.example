# === POLYMATH RAG v3.3 ===
# Copy this file to .env and fill in your secrets.
#
#   cp .env.example .env
#   # then edit .env — anything marked CHANGE_ME or empty must be filled
#
# Security:
#   - .env is gitignored. Never commit it.
#   - Generate secrets with `openssl rand -base64 64` (auth) or
#     `openssl rand -base64 32` (passwords).
#   - Cloud LLM keys are optional — the stack runs fully local via Ollama
#     if you set up any embedding/synthesis path with no cloud keys at all.

# ============================================================
# DATABASES
# ============================================================
MONGODB_URI=mongodb://polymath:CHANGE_ME_mongo_password@mongodb:27017/polymath?authSource=admin
MONGO_USER=polymath
MONGO_PASSWORD=CHANGE_ME_mongo_password

QDRANT_URL=http://qdrant:6333

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_password
# Set to false to skip the graph layer (vector-only retrieval, smaller footprint)
NEO4J_ENABLED=true

REDIS_URL=redis://redis:6379

# ============================================================
# LITELLM (cloud LLM router)
# ============================================================
LITELLM_URL=http://litellm:4000
# openssl rand -base64 32
LITELLM_MASTER_KEY=CHANGE_ME_litellm_master_key

# ============================================================
# LOCAL LLM (Ollama on host machine)
# ============================================================
# host.docker.internal works on Docker Desktop (Win/Mac).
# On native Linux Docker, use the host's bridge IP or set extra_hosts.
OLLAMA_URL=http://host.docker.internal:11434

# ============================================================
# AUTH
# ============================================================
# openssl rand -base64 64
AUTH_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_64
# Initial admin password. Change it after first login.
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_admin_password
# API key required by the MCP sidecar when MCP_REQUIRE_AUTH=true.
MCP_API_KEY=CHANGE_ME_mcp_api_key

# ============================================================
# CLOUD LLM PROVIDER KEYS (all optional — fill what you'll use)
# ============================================================
# At least ONE of these (or a working Ollama path) is needed for synthesis.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Below are optional providers wired through LiteLLM wildcard routes.
# Leave empty to disable. Non-empty placeholders ("ui-managed-placeholder")
# keep LiteLLM's wildcard route loadable when keys are managed per-user
# via Settings -> API Keys (Fernet-encrypted in MongoDB).
MISTRAL_API_KEY=
Z_AI_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
MIMO_API_KEY=

# ============================================================
# CLOUDFLARE TUNNEL (optional — for publishing the app behind your domain)
# ============================================================
CLOUDFLARE_TUNNEL_TOKEN=
# Public MCP base URL shown in Settings -> MCP snippets. Leave blank for localhost.
MCP_PUBLIC_URL=
# Keep true unless MCP is only reachable on a trusted local network.
MCP_REQUIRE_AUTH=true
# Default source chunk count for MCP retrieval tools when top_k is omitted.
MCP_DEFAULT_TOP_K=5

# ============================================================
# APPLICATION
# ============================================================
APP_ENV=development
LOG_LEVEL=info
# Default local workstation services. Remove mcp if you do not need agent
# access, or add cloudflare/admin/automation as needed.
COMPOSE_PROFILES=local-embed,local-rerank,local-parser,mcp

# ============================================================
# DOCKER VOLUME ROOT
# ============================================================
# All bind mounts live under this root. Use a fast SSD outside Docker
# Desktop's WSL VHDX so vector indexes don't bloat your virtual disk.
#   Windows:  C:/PolymathRuntime  or  E:/PolymathRuntime
#   Linux:    /mnt/ssd/polymath   or  $HOME/polymath-runtime
POLYMATH_DOCKER_DATA_ROOT=C:/PolymathRuntime
# Bind-mounted config/scripts that should travel with the runtime export.
POLYMATH_RUNTIME_BINDS_ROOT=C:/PolymathRuntime/binds
# HuggingFace caches stay here. Symlinks must be supported on the underlying
# filesystem (NTFS on Windows is fine; some network shares are not).
POLYMATH_CACHE_ROOT=C:/PolymathRuntime
# Where pre-staged model files live (Qwen3-Embedding-0.6B, ms-marco-MiniLM-L6-v2)
POLYMATH_MODELS_ROOT=C:/PolymathRuntime/models

# ============================================================
# RERANKER (cross-encoder ms-marco-MiniLM-L6-v2)
# ============================================================
RERANKER_URL=http://reranker:8080
LOCAL_RERANKER_ENABLED=true

# ============================================================
# DEFAULT MODELS (optional — falls back to per-user settings)
# ============================================================
DEFAULT_COMPLETION_MODEL=
AGENTIC_MODEL=
HYDE_MODEL=

# ============================================================
# EMBEDDING (Qwen3-Embedding-0.6B, 1024d)
# ============================================================
# Fits in ~2 GB VRAM at batch 64. Lower for cards with < 8 GB VRAM.
LOCAL_EMBEDDER_ENABLED=true
LOCAL_EMBED_BATCH_SIZE=64
EMBED_BATCH_SIZE=64

# ============================================================
# INGESTION CONCURRENCY
# ============================================================
# Doc-worker parallelism. Lower for small machines (24 GB VRAM and under
# work well at 4/4/4). Higher saturates >= 96 GB pro cards.
INGEST_PRE_VECTOR_DOC_CAP=8
INGEST_GRAPH_DOC_CAP=8
INGEST_MAX_PARSE_JOBS=8
INGEST_MAX_MODEL_PHASE_DOCS=8
INGEST_MAX_CLOUD_MODEL_PHASE_DOCS=4
INGEST_MAX_GRAPH_MODEL_PHASE_DOCS=8

# ============================================================
# EXTRACTION (Ghost B entity/relation extractor)
# ============================================================
# IMPORTANT: max_tokens must accommodate any reasoning-mode tokens AND
# the JSONL content. DeepSeek v4-flash defaults to thinking-mode ON:
# Ghost B disables it via thinking={"type":"disabled"} so reasoning
# tokens don't eat the entire budget — see GOTCHAS § "Ghost B + DeepSeek
# thinking-mode". If you swap to a non-DeepSeek reasoning model
# (Claude with extended thinking, OpenAI o-series, etc.), wire its
# disable knob the same way or budget for ~3x output tokens.
EXTRACTION_MAX_TOKENS=6144
EXTRACTION_OUTPUT_MODE=jsonl
EXTRACTION_JSON_OBJECT_MAX_ENTITIES_PER_CHUNK=8
EXTRACTION_JSON_OBJECT_MAX_RELATIONS_PER_CHUNK=12
EXTRACTION_JSON_OBJECT_MAX_FACTS_PER_CHUNK=4
EXTRACTION_EVIDENCE_MAX_CHARS=120
EXTRACTION_FACT_VALUE_MAX_CHARS=160
EXTRACTION_RESCUE_MAX_TOKENS=4096
EXTRACTION_MAX_INPUT_TOKENS=700
# Wall-clock cap on the per-doc chunker. Pathological content (code/math/
# table blocks with no sentence boundaries — see PBR4) can pin the chunker
# at 100% CPU for many minutes; this timeout marks the doc failed and the
# batch moves on. Raise if you have legitimately huge docs you want to
# process even if it takes >10 min.
TIER_CHUNKER_DOC_TIMEOUT_SECONDS=600
# Parser-side line cap. Set 15 above the per-type theoretical max
# (14 entities + 20 relations + 5 facts + 1 sentinel = 40). Going below
# the per-type max truncates dense chunks and surfaces them as
# `error_type=line_cap_exceeded` audit events even when the model output
# is clean. Bumping above ~64 is wasteful — model can't emit more
# distinct items because duplicates are forbidden.
EXTRACTION_MAX_TOTAL_LINES=55
EXTRACTION_RESCUE_MAX_TOTAL_LINES=30
EXTRACTION_JSONL_MAX_CALLS=2
EXTRACTION_FOREGROUND_MAX_CALLS=2
EXTRACTION_GLOBAL_MAX_CONCURRENT=180
EXTRACTION_MAX_ACTIVE_DOCS=1
EXTRACTION_FAILURE_PAUSE_PERCENT=25
EXTRACTION_FAILURE_PAUSE_MIN_CHUNKS=20
EXTRACTION_JSONL_DEBUG_RAW=false
EXTRACTION_ERROR_AUDIT_ENABLED=true
EXTRACTION_ERROR_AUDIT_MAX_FAILED_ATTEMPTS_PER_DOC=200
EXTRACTION_ERROR_AUDIT_MAX_SUCCESS_ATTEMPTS_PER_DOC=2
EXTRACTION_ERROR_AUDIT_RAW_FIRST_CHARS=200
EXTRACTION_ERROR_AUDIT_RAW_LAST_CHARS=400
EXTRACTION_MAX_ENTITIES_PER_CHUNK=18
EXTRACTION_MAX_RELATIONS_PER_CHUNK=20
EXTRACTION_RESCUE_MAX_ENTITIES_PER_CHUNK=8
EXTRACTION_RESCUE_MAX_RELATIONS_PER_CHUNK=8
EXTRACTION_ENABLE_FACTS=true
EXTRACTION_MAX_FACTS_PER_CHUNK=5
# 0.0 disables LLM-self-reported confidence filtering. Quality is enforced
# by the schema constraints; raise only after eyeballing your model's
# confidence distribution.
ENTITY_CONFIDENCE_THRESHOLD=0.0

# ============================================================
# LOCAL VLLM (optional — disable if you don't run vLLM extract/summary)
# ============================================================
# GPU memory split. 0.12 + 0.12 = ~24 GB on a 96 GB card, leaving headroom
# for embedder/docling/reranker. Raise only while watching nvidia-smi.
VLLM_EXTRACT_GPU_MEMORY_UTILIZATION=0.12
VLLM_EXTRACT_MAX_NUM_SEQS=256
VLLM_EXTRACT_MAX_MODEL_LEN=12288
VLLM_SUMMARY_GPU_MEMORY_UTILIZATION=0.12
VLLM_SUMMARY_MAX_NUM_SEQS=128
VLLM_SUMMARY_MAX_MODEL_LEN=12288
# WSL2 + WDDM doesn't release VRAM cleanly when vLLM containers stop;
# only `wsl --shutdown` reclaims. Keep idle-unload off unless you're on
# native Linux.
VLLM_IDLE_UNLOAD_ENABLED=false
VLLM_IDLE_CONTAINERS=polymath_v33-vllm-summary-1,polymath_v33-vllm-extract-1
LOCAL_VLLM_COMPACT_MAX_CONCURRENT=32
LOCAL_VLLM_NORMAL_MAX_CONCURRENT=64

# ============================================================
# AUTOMATION (optional — n8n workflow runner)
# ============================================================
N8N_URL=http://n8n:5678

# ============================================================
# E2E TEST KEYS (optional — only needed to run Playwright autoresearch tests)
# ============================================================
POLYMATH_TEST_KIMI_KEY=
POLYMATH_TEST_DEEPSEEK_KEY=
POLYMATH_TEST_OPENROUTER_KEY=
POLYMATH_TEST_MODAL_TOKEN_ID=
POLYMATH_TEST_MODAL_TOKEN_SECRET=
