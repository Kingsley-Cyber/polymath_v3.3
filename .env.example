# === POLYMATH RAG v3.3 ===
# Copy this file to .env and fill in your secrets
# NEVER commit .env to version control

# === DOCKER STORAGE ===
# Keep this outside Docker Desktop's own DataFolder. If Docker Desktop uses
# E:\Docker for its VHD, Polymath data/models should live somewhere else.
POLYMATH_DOCKER_DATA_ROOT=E:/PolymathRuntime
POLYMATH_MODELS_ROOT=E:/PolymathRuntime/models
LOCAL_EMBED_BATCH_SIZE=32
LOCAL_EMBEDDER_ENABLED=false
LOCAL_RERANKER_ENABLED=false

# === LOCAL INGESTION LLMs (vLLM on RTX PRO 6000) ===
# These services are enabled by the local-ingest-llm compose profile. Gemma may
# require an accepted Hugging Face license and token before the repair service
# can pull.
LOCAL_VLLM_API_KEY=local
LOCAL_LLM_NVIDIA_VISIBLE_DEVICES=0
LOCAL_LLM_NVIDIA_DEVICE_ID=0
HUGGING_FACE_HUB_TOKEN=
# Prefix caching is explicit for vLLM V0/V1 compatibility. Set a *_ARG to
# --no-enable-prefix-caching only when diagnosing cache-related serving issues.
VLLM_EXTRACT_MODEL=LiquidAI/LFM2-1.2B-Extract
VLLM_EXTRACT_SERVED_NAME=lfm2-extract
VLLM_EXTRACT_PREFIX_CACHING_ARG=--enable-prefix-caching
VLLM_EXTRACT_GPU_MEMORY_UTILIZATION=0.18
VLLM_EXTRACT_MAX_MODEL_LEN=8192
VLLM_EXTRACT_MAX_NUM_SEQS=128
VLLM_EXTRACT_MAX_NUM_BATCHED_TOKENS=65536
VLLM_SUMMARY_MODEL=LiquidAI/LFM2-1.2B-RAG
VLLM_SUMMARY_SERVED_NAME=lfm2-rag
VLLM_SUMMARY_PREFIX_CACHING_ARG=--enable-prefix-caching
VLLM_SUMMARY_GPU_MEMORY_UTILIZATION=0.24
VLLM_SUMMARY_MAX_MODEL_LEN=12288
VLLM_SUMMARY_MAX_NUM_SEQS=64
VLLM_SUMMARY_MAX_NUM_BATCHED_TOKENS=32768
VLLM_TRANSCRIPT_MODEL=LiquidAI/LFM2-2.6B-Transcript
VLLM_TRANSCRIPT_SERVED_NAME=lfm2-transcript
VLLM_TRANSCRIPT_PREFIX_CACHING_ARG=--enable-prefix-caching
VLLM_TRANSCRIPT_GPU_MEMORY_UTILIZATION=0.24
VLLM_TRANSCRIPT_MAX_MODEL_LEN=12288
VLLM_TRANSCRIPT_MAX_NUM_SEQS=32
VLLM_TRANSCRIPT_MAX_NUM_BATCHED_TOKENS=32768
VLLM_REPAIR_MODEL=google/gemma-4-E4B
VLLM_REPAIR_SERVED_NAME=gemma4-e4b
VLLM_REPAIR_PREFIX_CACHING_ARG=--enable-prefix-caching
VLLM_REPAIR_GPU_MEMORY_UTILIZATION=0.30
VLLM_REPAIR_MAX_MODEL_LEN=8192
VLLM_REPAIR_MAX_NUM_SEQS=16
VLLM_REPAIR_MAX_NUM_BATCHED_TOKENS=16384
# Local vLLM can handle multiple model-phase documents; reduce to 1 when
# pointing ingestion pools at external/cloud APIs with stricter rate limits.
INGEST_MAX_MODEL_PHASE_DOCS=2
GRAPH_REPAIR_WORKER_ENABLED=true
GRAPH_REPAIR_WORKER_CONCURRENCY=2
GRAPH_REPAIR_WORKER_POLL_SECONDS=2.0
GRAPH_REPAIR_LEASE_SECONDS=300

# === DATABASES ===
MONGODB_URI=mongodb://mongodb:27017/polymath
QDRANT_URL=http://qdrant:6333

# === NEO4J ===
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# === LITELLM ===
LITELLM_URL=http://litellm:4000
LITELLM_MASTER_KEY=your_litellm_master_key_here

# === LLM PROVIDER API KEYS ===
# All routed through LiteLLM via wildcard/OpenAI-passthrough patterns.
# Call format from backend: model = "<prefix>/<model-name>"
# Examples: openai/gpt-4o, anthropic/claude-sonnet-4, deepseek/deepseek-chat,
#           gemini/gemini-2.5-pro, mistral/mistral-large-latest,
#           glm-coding/glm-4.6, kimi/kimi-k2-0905-preview,
#           minimax/MiniMax-M1, mimo/mimo-7b-rl, mimo-coding/mimo-coding-v2
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
# Zhipu / z.ai — coding endpoint (https://api.z.ai/api/coding/paas/v4)
Z_AI_API_KEY=
# Moonshot (Kimi) — https://api.moonshot.ai/v1
MOONSHOT_API_KEY=
# MiniMax intl — https://api.minimaxi.chat/v1
MINIMAX_API_KEY=
# Xiaomi MiMo-v2 — single key serves base (api.xiaomimimo.com) + coding (token-plan-sgp.xiaomimimo.com)
MIMO_API_KEY=

# === OLLAMA ===
OLLAMA_URL=http://host.docker.internal:11434

# === REDIS ===
REDIS_URL=redis://redis:6379

# === MODAL CLOUD GPU (Phase 14.3 — primary ingestion embed path) ===
# Modal is the primary production embedding path during ingestion.
# When MODAL_ENABLED=true, new corpora default to embed_mode="modal_tei".
# Query-path embedding always runs locally regardless of this setting.
# Webhook URL format: https://<workspace>--<app-name>-<function-name>.modal.run
# See: modal.com/docs/guide/webhook-urls
MODAL_ENABLED=false
MODAL_EMBEDDER_URL=
MODAL_API_KEY=
MODAL_TIMEOUT_SECONDS=300.0

# === SILICONFLOW CLOUD API (alternative cloud embedding provider) ===
# OpenAI-compatible /embeddings API. Pick SiliconFlow OR Modal, not both on
# the same corpus (embed_mode is frozen at corpus creation time).
# The SILICONFLOW_API_KEY is Bearer-authenticated; never round-tripped to frontend.
SILICONFLOW_ENABLED=false
SILICONFLOW_EMBEDDER_URL=https://api.siliconflow.com/v1/embeddings
SILICONFLOW_API_KEY=
SILICONFLOW_TIMEOUT_SECONDS=120.0

# === AGENTIC MODE (Phase 14.1) ===
# Global default — users can override per-request from the chat UI.
# Agentic model must support function-calling (tools).
AGENTIC_MODE_ENABLED=false
AGENTIC_MODEL=

# === HYDE (Phase 17) ===
# Dedicated cheap/fast model for Hypothetical Document Embeddings.
# When the user toggles HyDE ON, this model writes a 2-3 sentence hypothetical
# answer that is embedded (instead of the raw question) for Qdrant search.
# Answer-shaped vectors match answer-shaped chunks → better recall.
HYDE_MODEL=

# === CLOUDFLARE TUNNEL ===
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# === APPLICATION ===
APP_ENV=development
LOG_LEVEL=info
